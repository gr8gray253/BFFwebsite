# Cloudflare Pages — Security & Cache Headers
# Applied automatically on deploy. No build step needed.

# ── Security headers (all pages) ─────────────────────────────────────────────
/*
  Strict-Transport-Security: max-age=31536000; includeSubDomains; preload
  X-Frame-Options: DENY
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(), microphone=(), geolocation=(self), payment=(self "https://www.zeffy.com")
  X-XSS-Protection: 1; mode=block
  # External dependencies: unpkg (Leaflet+SRI), Google Fonts, ArcGIS tiles, Zeffy, Supabase
  # 'unsafe-inline' removed from script-src — app.js + sw-register.js are external; theme FOUC script allowed via SHA-256 hash
  Content-Security-Policy: default-src 'self'; script-src 'self' https://unpkg.com https://cdn.jsdelivr.net https://static.cloudflareinsights.com 'sha256-Jgmj6t6ZzkH3ct6eFPxSLAbGhhkzxq0Ix9X96/cRDgI='; style-src 'self' https://fonts.googleapis.com https://unpkg.com 'unsafe-inline'; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: blob: https://*.tile.openstreetmap.org https://unpkg.com https://*.supabase.co https://server.arcgisonline.com https://services.arcgisonline.com https://lh3.googleusercontent.com https://graph.facebook.com https://tiles.openseamap.org; connect-src 'self' https://*.supabase.co https://api.open-meteo.com https://unpkg.com; frame-src https://www.zeffy.com; form-action 'self'; frame-ancestors 'none'; base-uri 'self'; object-src 'none'

# ── Cache: Photos and videos (1 year — immutable filenames) ──────────────────
/Photos/*
  Cache-Control: public, max-age=31536000, immutable

# ── Cache: HTML pages (always revalidate) ────────────────────────────────────
/*.html
  Cache-Control: public, max-age=0, must-revalidate

# ── Cache: Service worker (never cache — must always be fresh) ───────────────
/sw.js
  Cache-Control: no-store
