# Cloudflare Pages — Security & Cache Headers
# Applied automatically on deploy. No build step needed.

# ── Security headers (all pages) ─────────────────────────────────────────────
/*
  X-Frame-Options: DENY
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(), microphone=(), geolocation=(self), payment=()
  X-XSS-Protection: 1; mode=block
  # External dependencies: unpkg (Leaflet+SRI), Google Fonts, OpenStreetMap tiles, Formspree
  # 'unsafe-inline' required — site uses inline <script> and <style> blocks (single-file architecture)
  Content-Security-Policy: default-src 'self'; script-src 'self' https://unpkg.com 'unsafe-inline'; style-src 'self' https://fonts.googleapis.com https://unpkg.com 'unsafe-inline'; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: blob: https://*.tile.openstreetmap.org https://unpkg.com; connect-src 'self' https://formspree.io; form-action 'self' https://formspree.io; frame-ancestors 'none'; base-uri 'self'; object-src 'none'

# ── Block internal files from indexing (also 404'd via _redirects) ───────────
/NEXT_STEPS.md
  X-Robots-Tag: noindex, nofollow
/README.md
  X-Robots-Tag: noindex, nofollow
/netlify.toml
  X-Robots-Tag: noindex, nofollow
/.claude/*
  X-Robots-Tag: noindex, nofollow

# ── Cache: Photos and videos (1 year — immutable filenames) ──────────────────
/Photos/*
  Cache-Control: public, max-age=31536000, immutable

# ── Cache: HTML pages (always revalidate) ────────────────────────────────────
/*.html
  Cache-Control: public, max-age=0, must-revalidate
